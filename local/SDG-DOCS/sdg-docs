#!/bin/bash

# sdg-docs: SDG-OS Documentation Browser
# Pick a module → pick a doc → read it. That's it.

DOCS_DIR="$HOME/.local/docs"
SCRIPT_PATH="$(readlink -f "$0")"

# ── Level 0: Module Picker ─────────────────────────────────────────────────────
# Shows each doc module. Preview shows the docs inside the highlighted module.
# Enter drills into the module's doc list.

level0() {
    local modules=()
    for dir in "$DOCS_DIR"/SDG-DOC-*/; do
        [ -d "$dir" ] || continue
        modules+=("$(basename "$dir")")
    done

    [ ${#modules[@]} -eq 0 ] && { echo "No documentation found."; exit 1; }

    printf '%s\n' "${modules[@]}" \
        | fzf --layout=reverse \
              --prompt='module > ' \
              --preview="_tree_preview {}" \
              --preview-window='right:60%:wrap' \
              --bind="enter:become($SCRIPT_PATH --from {})"
}

# ── Level 1: Doc Picker ────────────────────────────────────────────────────────
# Shows .md files inside the chosen module. Preview shows the document.
# Enter opens it with bat. Escape goes back to the module list.

level1() {
    local module="$1"
    local dir="$DOCS_DIR/$module"

    [ ! -d "$dir" ] && { echo "Module not found: $module"; exit 1; }

    local files=()
    while IFS= read -r -d '' f; do
        files+=("$(basename "$f")")
    done < <(find "$dir" -maxdepth 1 -name '*.md' -type f -print0 2>/dev/null | sort -z)

    [ ${#files[@]} -eq 0 ] && { echo "No docs in $module."; exit 1; }

    printf '%s\n' "${files[@]}" \
        | fzf --layout=reverse \
              --prompt="$module > " \
              --preview="bat --style=plain -f '$dir/{}'" \
              --preview-window='right:60%:wrap' \
              --bind="enter:execute(bat --style=plain -f '$dir/{}')" \
              --bind="escape:become($SCRIPT_PATH)"
}

# ── Tree Preview: shows what's inside a module at level 0 ─────────────────────

_tree_preview() {
    local name="$1"
    local dir="$DOCS_DIR/$name"

    [ ! -d "$dir" ] && { echo "Not found: $name"; return; }

    local files=()
    while IFS= read -r -d '' f; do
        files+=("$(basename "$f")")
    done < <(find "$dir" -maxdepth 1 -name '*.md' -type f -print0 2>/dev/null | sort -z)

    local count=${#files[@]}
    echo "── $name ($count docs) ──"
    echo ""

    local i=0
    for doc in "${files[@]}"; do
        i=$((i + 1))
        if [ "$i" -eq "$count" ]; then
            echo "└── $doc"
        else
            echo "├── $doc"
        fi
    done

    [ "$count" -eq 0 ] && echo "(no docs)"
}

# ── Entry ──────────────────────────────────────────────────────────────────────

if [ "$1" = "--from" ] && [ -n "$2" ]; then
    level1 "$2"
else
    level0
fi
